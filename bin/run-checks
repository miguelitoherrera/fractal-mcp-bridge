#!/bin/bash
set -e

# Navigate to project root
cd "$(dirname "$0")/.."

echo "--- 🎨 Checking formatting (Ruff) ---"
.venv/bin/ruff format --check src tests

echo "--- 🔍 Linting (Ruff) ---"
.venv/bin/ruff check src tests

echo "--- 📝 Type checking (Mypy) ---"
.venv/bin/mypy src tests

echo "--- 🧪 Running tests (Pytest) ---"
# Run tests with JIT disabled and project package included
# No PYTHONPATH hack needed once installed, but -m pytest ensures src is in path
NUMBA_DISABLE_JIT=1 .venv/bin/python -m pytest \
    --cov=fractal_mcp \
    --cov-report=term-missing \
    --cov-report=html \
    tests "$@"

echo "--- ✅ All checks passed! ---"
